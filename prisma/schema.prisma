generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  ADMIN
  SALESPERSON
}

enum CustomerStatus {
  ACTIVE
  INACTIVE
}

enum OrderStatus {
  PENDING_ADMIN
  CONFIRMED
  CANCELLED
  DELIVERED
}

enum PaymentType {
  CASH
  BANK
}

enum PaymentStatus {
  PENDING
  CONFIRMED
  REJECTED
}

enum LoanStatus {
  OPEN
  CLOSED
}

enum LedgerType {
  DEBIT
  CREDIT
}

enum LedgerCategory {
  SALE
  SALARY
  EXPENSE
  OTHER_INCOME
}

enum StockEvent {
  order
  restock
  adjustment
  return
}

model User {
  id            Int           @id @default(autoincrement())
  username      String        @unique
  password_hash String
  role          Role
  email         String?
  phone_number  String?
  photo_url     String?
  is_active     Boolean       @default(true)
  remark        String?
  created_at    DateTime      @default(now())

  salesperson   Salesperson?
  orders        Order[]       @relation("SalespersonOrders")
  payments      Payment[]     @relation("PaymentCollectedBy")

  @@index([role])
}

model Salesperson {
  id             Int     @id @default(autoincrement())
  user_id        Int     @unique
  name           String
  region         String?
  monthly_target Decimal @db.Decimal(12, 2)

  user User @relation(fields: [user_id], references: [id])
}

model Customer {
  id           Int            @id @default(autoincrement())
  name         String
  phone_number String
  address      String
  status       CustomerStatus
  notes        String?

  orders   Order[]
  payments Payment[]
  loans    Loan[]

  @@index([phone_number])
}

model Supplier {
  id           Int      @id @default(autoincrement())
  name         String
  phone_number String
  address      String
  created_at   DateTime @default(now())

  expenses Expense[]

  @@index([phone_number])
}

model Product {
  id            Int             @id @default(autoincrement())
  name          String
  description   String?
  category      String
  unit_price    Decimal         @db.Decimal(12, 2)
  pcs_per_dozen Decimal         @default(12) @db.Decimal(12, 2)
  pcs_per_box   Decimal         @default(24) @db.Decimal(12, 2)
  photo_url     String
  is_active     Boolean         @default(true)

  inventory     Inventory?
  orderItems    OrderItem[]
  stockHistory  StockHistory[]

  @@index([category])
  @@index([is_active])
}

model Inventory {
  product_id Int @id
  quantity   Int

  product Product @relation(fields: [product_id], references: [id])
}

model StockHistory {
  id              Int         @id @default(autoincrement())
  product_id      Int
  event           StockEvent
  change_quantity Int
  inventory_after Int
  source          String?
  created_at      DateTime    @default(now())

  product Product @relation(fields: [product_id], references: [id])

  @@index([product_id])
  @@index([created_at])
}

model Order {
  id                   Int         @id @default(autoincrement())
  customer_id          Int
  salesperson_user_id  Int
  total_amount         Decimal     @db.Decimal(12, 2)
  status               OrderStatus
  created_at           DateTime    @default(now())
  payment_type         PaymentType?
  remark               String?

  customer    Customer @relation(fields: [customer_id], references: [id])
  salesperson User     @relation("SalespersonOrders", fields: [salesperson_user_id], references: [id])
  items       OrderItem[]
  loan        Loan?
  payments    Payment[]

  @@index([customer_id])
  @@index([salesperson_user_id])
  @@index([status])
}

model OrderItem {
  id         Int     @id @default(autoincrement())
  order_id   Int
  product_id Int
  quantity   Int
  unit_type  String  @default("Pcs")
  unit_price Decimal @db.Decimal(12, 2)

  order   Order   @relation(fields: [order_id], references: [id])
  product Product @relation(fields: [product_id], references: [id])

  @@index([order_id])
  @@index([product_id])
}

model Payment {
  id                   Int           @id @default(autoincrement())
  customer_id          Int
  order_id             Int?
  collected_by_user_id Int
  amount_paid          Decimal       @db.Decimal(12, 2)
  payment_type         PaymentType
  status               PaymentStatus
  created_at           DateTime      @default(now())

  customer     Customer @relation(fields: [customer_id], references: [id])
  order        Order?   @relation(fields: [order_id], references: [id])
  collected_by User     @relation("PaymentCollectedBy", fields: [collected_by_user_id], references: [id])

  @@index([customer_id])
  @@index([order_id])
  @@index([status])
}

model Loan {
  id               Int        @id @default(autoincrement())
  customer_id      Int
  order_id         Int        @unique
  original_amount  Decimal    @db.Decimal(12, 2)
  remaining_amount Decimal    @db.Decimal(12, 2)
  status           LoanStatus

  customer Customer @relation(fields: [customer_id], references: [id])
  order    Order    @relation(fields: [order_id], references: [id])

  @@index([customer_id])
  @@index([status])
}

model LedgerEntry {
  id                 Int            @id @default(autoincrement())
  entry_date         DateTime       @db.Date
  type               LedgerType
  category           LedgerCategory
  reference_id       Int
  amount             Decimal        @db.Decimal(12, 2)
  description        String?
  is_system_generated Boolean       @default(false)

  @@index([entry_date])
  @@index([type])
  @@index([category])
}

model DailyBalance {
  date            DateTime @id @db.Date
  opening_balance Decimal  @db.Decimal(12, 2)
  closing_balance Decimal  @db.Decimal(12, 2)
}

model Employee {
  id           Int       @id @default(autoincrement())
  name         String
  phone        String    @db.VarChar(20)
  address      String?
  position     String?   @db.VarChar(100)
  basic_salary Decimal   @db.Decimal(12, 2)
  start_date   DateTime? @db.Date
  remark       String?
  created_at   DateTime  @default(now())

  salaries SalaryRecord[]
}

model SalaryRecord {
  id               Int      @id @default(autoincrement())
  employee_id      Int
  salary_month     String   @default("") @db.VarChar(7)
  basic_salary     Decimal  @db.Decimal(12, 2)
  bonus_amount     Decimal  @db.Decimal(12, 2)
  bonus_types      Json?
  deduction_amount Decimal  @db.Decimal(12, 2)
  net_salary       Decimal  @db.Decimal(12, 2)
  payment_date     DateTime @default(now()) @db.Date
  remark           String?
  created_at       DateTime @default(now())

  employee Employee @relation(fields: [employee_id], references: [id])

  @@index([employee_id])
  @@index([salary_month])
}

model Category {
  id         Int      @id @default(autoincrement())
  name       String   @unique @db.VarChar(100)
  created_at DateTime @default(now())
}

model Expense {
  id             Int         @id @default(autoincrement())
  expenseCode    String      @unique @db.VarChar(20)
  category       String?     @db.VarChar(100)
  description    String
  amount         Decimal     @db.Decimal(12, 2)
  payment_method PaymentType
  expense_date   DateTime    @default(now()) @db.Date
  created_at     DateTime    @default(now())

  supplier_id Int?
  supplier    Supplier? @relation(fields: [supplier_id], references: [id], onDelete: SetNull)

  @@index([supplier_id])
}

model SystemSettings {
  id          Int      @id @default(1)
  system_name String   @default("NYK Cosmetics")
  system_logo String?
  updated_at  DateTime @updatedAt
}
